server {
    server_name emotions-guide.ru www.emotions-guide.ru;  # укажите свой домен или IP адрес

    # Обслуживание React приложения
    location / {
        root /var/www/mysite/Frontend/dist;  # путь к собранному React приложению
        try_files $uri /index.html; 
    }

    # Проксирование API запросов к FastAPI
    location /api {
        proxy_pass http://127.0.0.1:8000;     # FastAPI слушает локально на 8000 порту
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Кеширование статических файлов React (рекомендуется)
    location /static {
        root /var/www/mysite/Frontend/dist;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/emotions-guide.ru/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/emotions-guide.ru/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}
server {
    if ($host = www.emotions-guide.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = emotions-guide.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name emotions-guide.ru www.emotions-guide.ru;
    return 301 https://$host$request_uri;




}
